<script>
(function () {

  var applying = false;

  /* ══════════════════════════════════════════════════
     LANGUAGE DETECTION — priority order:
     1. html[lang] set by Wix Multilingual on the parent page
        (propagates into the iframe via document.referrer / lang attr)
     2. URL path  /es/  (Wix Multilingual URL prefix)
     3. URL query ?lang=es or ?language=es
     4. Browser navigator.language
  ══════════════════════════════════════════════════ */
  function detectLang() {
    // 1. html[lang] on this document (Wix may set it)
    var attr = (document.documentElement.lang || '').toLowerCase();
    if (attr.startsWith('es')) return 'es';

    // 2. URL path prefix  /es/
    var path = window.location.pathname.toLowerCase();
    if (path.indexOf('/es/') !== -1 || path.startsWith('/es')) return 'es';

    // 3. Query string
    var search = window.location.search.toLowerCase();
    if (search.indexOf('lang=es') !== -1 || search.indexOf('language=es') !== -1) return 'es';

    // 4. Browser / OS language preference
    var nav = (navigator.language || navigator.userLanguage || '').toLowerCase();
    if (nav.startsWith('es')) return 'es';

    return 'en';
  }

  /* ══════════════════════════════════════════════════
     AUTO HEIGHT — reports scroll height to Wix parent
     so the HTML iFrame element resizes to fit content.
  ══════════════════════════════════════════════════ */
  function reportHeight() {
    try {
      window.parent.postMessage(
        JSON.stringify({ type: 'gsl-height', height: document.body.scrollHeight }),
        '*'
      );
    } catch (e) {}
  }

  /* ══════════════════════════════════════════════════
     APPLY LANGUAGE
  ══════════════════════════════════════════════════ */
  function applyLang(lang) {
    applying = true;
    document.documentElement.lang = lang;
    applying = false;
    document.body.classList.toggle('lang-es', lang === 'es');
    document.querySelectorAll('[data-en][data-es]').forEach(function (el) {
      el.innerHTML = el.getAttribute('data-' + lang);
    });
    fixWidows();
    reportHeight();
  }

  /* ══════════════════════════════════════════════════
     WIDOW PREVENTION
  ══════════════════════════════════════════════════ */
  function fixWidows() {
    ['.circ-body', '.circ-meta', '.footer-banner p'].forEach(function (sel) {
      document.querySelectorAll(sel).forEach(function (el) {
        el.childNodes.forEach(function (node) {
          if (node.nodeType === 3) {
            var t = node.textContent, i = t.lastIndexOf(' ');
            if (i > -1) node.textContent = t.slice(0, i) + '\u00A0' + t.slice(i + 1);
          }
        });
        var last = el.lastElementChild;
        if (last) last.childNodes.forEach(function (node) {
          if (node.nodeType === 3) {
            var t = node.textContent, i = t.lastIndexOf(' ');
            if (i > -1) node.textContent = t.slice(0, i) + '\u00A0' + t.slice(i + 1);
          }
        });
      });
    });
  }

  /* ── Init ── */
  applyLang(detectLang());

  /* Watch html[lang] — Wix Multilingual updates this attribute */
  var observer = new MutationObserver(function () {
    if (applying) return;
    applyLang(detectLang());
  });
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['lang'] });

  /* Poll for Wix SPA URL changes */
  var lastHref = window.location.href;
  setInterval(function () {
    if (window.location.href !== lastHref) {
      lastHref = window.location.href;
      applyLang(detectLang());
    }
  }, 300);

  /* Re-report height on resize (device rotation, zoom, etc.) */
  window.addEventListener('resize', reportHeight);
  window.addEventListener('load', reportHeight);

})();
</script>
