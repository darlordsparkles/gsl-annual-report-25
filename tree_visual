<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>GSL Annual Report 2025</title>
<link href="https://fonts.googleapis.com/css2?family=Source+Sans+Pro:ital,wght@0,400;0,700;1,400&family=Playfair+Display:wght@400&display=swap" rel="stylesheet"/>
<style>
/* ─── RESET ─── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body { width: 100%; overflow-x: hidden; }
body { font-family: 'Source Sans Pro', sans-serif; background: #F6F6F6; -webkit-font-smoothing: antialiased; }
.page { width: 100%; }

/* ══════════════════════════════════════════════════════════
   DESKTOP  ≥ 1101px  —  Canvas: 1920 × 905px
══════════════════════════════════════════════════════════ */
.scene {
  position: relative;
  width: 100%;
  aspect-ratio: 1920 / 905;
  background: #F6F6F6;
  overflow: hidden;
}

/* ── Background tree (desktop) ── */
.deco-trunk { position: absolute; width: 16.505%; left: 42.506%; top: 59.380%; z-index: 1; }
.deco-trunk svg { width: 100%; height: auto; display: block; }
.deco-trunk-tablet { display: none; }

.deco-ell-a {
  position: absolute; width: 10.325%; aspect-ratio: 1/1;
  left: 37.810%; top: 61.150%;
  background: #E2F1E3; border-radius: 9999px; z-index: 1;
}
.deco-ell-b {
  position: absolute; width: 6.471%; padding-bottom: 6.471%; height: 0;
  left: 53.630%; top: 58.453%;
  background: #E2F1E3; border-radius: 9999px; z-index: 4;
}

/* ── Circles ── */
.circ {
  position: absolute;
  width: 26.615%; aspect-ratio: 1/1;
  border-radius: 50%; overflow: hidden;
  top: 12.376%;
}
.circ-seeds    { background: #FDD1A5; left: 10.052%; z-index: 2; }
.circ-roots    { background: #FFC1CB; left: 36.667%; z-index: 3; }
.circ-branches { background: #C7E2C8; left: 63.281%; z-index: 2; }

/* ── Icon ── */
.circ-icon { position: absolute; overflow: visible; }
.circ-seeds .circ-icon,
.circ-roots .circ-icon,
.circ-branches .circ-icon { left: 57.14%; top: 10.18%; width: 19.18%; aspect-ratio: 1/1; }
.circ-icon svg { width: 100%; height: 100%; display: block; }

/* ══════════════════════════════════════════════════════════
   TEXT CONTENT GROUP
   All four text elements live inside .circ-content so they
   move as one block. padding-bottom: 10px ensures no text
   touches the circle's curved bottom edge.
══════════════════════════════════════════════════════════ */
.circ-content {
  position: absolute;
  /* Left edge: same 20.745% for Seeds/Roots; overridden per circle */
  left:   20.745%;
  right:  8%;          /* keeps text away from right curve */
  top:    24.07%;      /* starts at title position */
  bottom: 10px;        /* 10px clearance from bottom of circle */
  overflow: hidden;    /* clip if content still overflows circle bottom */
  display: flex;
  flex-direction: column;
  gap: 0;
}
.circ-branches .circ-content { left: 20.745%; }

/* ── Title ── */
.circ-title {
  font-family: 'Source Sans Pro', sans-serif;
  font-weight: 700;
  font-size: clamp(11px, 0.9375vw, 18px);
  line-height: 1.4;
  color: #000;
  white-space: nowrap;
  flex-shrink: 0;
  text-wrap: balance;
}

/* ── Rule ── */
.circ-rule { height: 2px; flex-shrink: 0; margin: 0.3em 0 0.45em; }
.circ-seeds    .circ-rule { width: 28.18%; background: #FFA449; }
.circ-roots    .circ-rule { width: 29.35%; background: #F8546D; }
.circ-branches .circ-rule { width: 28.96%; background: #69CE6C; }
/* Rule width is % of .circ-content width — keep proportional */

/* ── Subtitle ── */
.circ-meta {
  font-family: 'Source Sans Pro', sans-serif;
  font-size: clamp(10px, 0.8333vw, 16px);
  line-height: 1.4;
  color: #000;
  flex-shrink: 0;
  margin-bottom: 0.6em;
  text-wrap: balance;
  word-spacing: -0.01em;
}

/* ── Body ── */
.circ-body {
  font-family: 'Source Sans Pro', sans-serif;
  font-size: clamp(9.5px, 0.8333vw, 16px);
  line-height: 1.4;
  color: #000;
  padding-bottom: 10px;
  padding-right: 20px;   /* 20px narrower on the right, left stays aligned */
  text-wrap: pretty;
  overflow-wrap: break-word;
}

/* ══════════════════════════════════════════════════════════
   FOOTER
══════════════════════════════════════════════════════════ */
.footer-banner {
  width: 100%; background: #CBE2EC;
  backdrop-filter: blur(2px); -webkit-backdrop-filter: blur(2px);
  display: flex; align-items: center; justify-content: center;
  min-height: clamp(80px, 9.115vw, 175px);
  padding: clamp(20px, 3.5vw, 56px) clamp(24px, 10vw, 200px);
}
.footer-banner p {
  font-family: 'Playfair Display', serif; font-weight: 400;
  font-size: clamp(16px, 1.667vw, 32px); line-height: 1.4;
  text-align: center; color: #000;
  max-width: clamp(300px, 58vw, 1114px);
  text-wrap: balance;
}
.footer-mobile  { display: none; }
.footer-desktop { display: block; }

/* ══════════════════════════════════════════════════════════
   TABLET  769px – 1100px  —  Canvas: 1027 × 1366px
══════════════════════════════════════════════════════════ */
@media (min-width: 769px) and (max-width: 1100px) {
  .scene { aspect-ratio: 1027 / 1366; }
  .circ { width: 49.756%; top: 8.052%; }
  .circ-seeds    { left:  0.292%; z-index: 2; }
  .circ-roots    { left: 49.951%; z-index: 3; }
  .circ-branches { left: 25.122%; top: 40.263%; z-index: 4; }

  .deco-trunk { display: none; }
  .deco-trunk-tablet {
    display: block; position: absolute;
    left: 38.851%; top: 71.228%; width: 22.102%; z-index: 1;
  }
  .deco-trunk-tablet svg { width: 100%; height: auto; display: block; }
  .deco-ell-a { left: 31.938%; top: 74.231%; width: 13.827%; aspect-ratio: 1/1; padding-bottom: unset; height: unset; z-index: 2; }
  .deco-ell-b { left: 53.749%; top: 70.790%; width: 8.667%; padding-bottom: 8.667%; height: 0; z-index: 5; }

  .circ-title { font-size: clamp(12px, 1.753vw, 18px); }
  .circ-meta  { font-size: clamp(11px, 1.558vw, 16px); }
  .circ-body  { font-size: clamp(10px, 1.558vw, 16px); }
  .footer-banner p { font-size: clamp(14px, 1.753vw, 18px); }
}

/* ══════════════════════════════════════════════════════════
   MOBILE  ≤ 768px  —  Figma canvas: 402 × 1729px
   Circles: 511×511px, centered on viewport
   All text: center-aligned, matching Figma positions exactly
══════════════════════════════════════════════════════════ */
@media (max-width: 768px) {
  .scene {
    position: relative; width: 100%; height: 1729px;
    overflow: hidden; aspect-ratio: unset; display: block;
  }
  .deco-trunk { display: none; }

  /* ── Circles: 511×511, centered ── */
  .circ {
    position: absolute; width: 511px; height: 511px;
    padding-bottom: 0; aspect-ratio: unset;
    border-radius: 50%; overflow: hidden;
    left: 50%; transform: translateX(-50%);
  }
  .circ-seeds    { top:  93px; z-index: 2; }
  .circ-roots    { top: 509px; z-index: 3; }
  .circ-branches { top: 920px; z-index: 4; }

  /* ── Icon: centered horizontally, Figma top values ──
     Icon is 94px wide → center offset = 94/2 = 47px */
  .circ-seeds    .circ-icon,
  .circ-roots    .circ-icon,
  .circ-branches .circ-icon {
    left: calc(50% - 47px);
    width: 94px; height: 94px;
    aspect-ratio: unset;
  }
  .circ-seeds    .circ-icon { top: 25px; }
  .circ-roots    .circ-icon { top: 30px; }
  .circ-branches .circ-icon { top: 37px; }

  /* ── Content group: full circle width, centered, flex column ──
     Top = Figma title position per circle.
     Bottom = 10px clearance from circle edge. */
  .circ-content {
    left: 0; right: 0;
    bottom: 10px;
    overflow: hidden;
    align-items: center;
    text-align: center;
  }
  .circ-seeds    .circ-content { top: 134px; }
  .circ-roots    .circ-content { top: 139px; }
  /* left/right explicitly overrides the higher-specificity desktop rule on line 78 */
  .circ-branches .circ-content { top: 151px; left: 0; right: 0; }

  /* ── Title ── */
  .circ-title {
    font-size: 18px !important;
    line-height: 1.4 !important;
    white-space: nowrap;
    text-align: center;
    width: 100%;
  }

  /* ── Rule: centered, fixed width ── */
  .circ-rule {
    height: 2px !important;
    width: 80px !important;  /* centred under title */
    margin: 5px auto 8px !important;
    display: block;
  }

  /* ── Subtitle ── */
  .circ-meta {
    font-size: 16px !important;
    line-height: 1.4 !important;
    text-align: center;
    width: 100%;
    padding: 0 15%;
  }

  /* ── Body: centered, Figma widths ── */
  .circ-body {
    font-size: 16px !important;
    line-height: 1.4 !important;
    text-align: center;
    padding-left: 0;
    padding-right: 0;
    padding-bottom: 10px;
  }
  /* Figma body widths: Seeds 326px, Roots 286px, Branches 308px */
  .circ-seeds    .circ-body { padding-left: 18%; padding-right: 18%; }
  .circ-roots    .circ-body { padding-left: 22%; padding-right: 22%; }
  .circ-branches .circ-body { padding-left: 20%; padding-right: 20%; }

  /* ── Tree decoration — exact Figma px positions ── */
  .deco-trunk-tablet {
    display: block; position: absolute;
    left: calc(50% - 128.5px); top: 1327px; width: 303px; z-index: 1;
  }
  .deco-ell-a {
    position: absolute; left: calc(50% - 190.5px); top: 1388px;
    width: 142px; height: 142px; padding-bottom: 0; aspect-ratio: unset;
    background: #E2F1E3; border-radius: 9999px; z-index: 2;
  }
  .deco-ell-b {
    position: absolute; left: calc(50% + 75.5px); top: 1355px;
    width: 115px; height: 115px; padding-bottom: 0;
    background: #E2F1E3; border-radius: 9999px; z-index: 5;
  }

  /* ── Footer ── */
  .footer-banner { min-height: 133px; padding: 20px 33px; }
  .footer-banner p { font-size: 18px; line-height: 1.4; max-width: 100%; }
  .footer-mobile  { display: block; }
  .footer-desktop { display: none; }
}

.mobile-tree { display: none !important; }
</style>
</head>
